<Project Sdk="Microsoft.NET.Sdk">

  <!--
    A perfectly ordinary console app. References NOTHING inspector-related — its source is unmodified,
    exactly like a real target. The inspector arrives purely via the DOTNET_STARTUP_HOOKS env var.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>Target</AssemblyName>
    <RootNamespace>Target</RootNamespace>
  </PropertyGroup>

</Project>
