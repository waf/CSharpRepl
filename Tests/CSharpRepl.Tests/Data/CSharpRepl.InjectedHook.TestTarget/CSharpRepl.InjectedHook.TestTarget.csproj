<Project Sdk="Microsoft.NET.Sdk">

  <!--
    A stand-in for an ordinary, unmodified .NET app that the M1 integration test connects. It references
    nothing connector-related; the connector is injected purely via DOTNET_STARTUP_HOOKS at launch. Built as
    a normal framework-dependent executable (apphost) so the launched process id equals the managed process
    id the connector advertises. Not part of the product; only the test consumes it (ReferenceOutputAssembly=false).
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- An ordinary Generic Host, so the integration tests exercise the bootstrap's DI-root capture. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.8" />
  </ItemGroup>

</Project>
